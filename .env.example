# Medical Device Data Aggregation System - Environment Variables

# Application
DEBUG=true
APP_NAME=Medical Device Data Aggregation API

# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=medical_data
POSTGRES_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# RabbitMQ (queue/exchange topology lives in src/messaging.py)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# API
API_PORT=8000
API_KEY_LENGTH=32
# Secrets. These dev values run locally (DEBUG=true); in production (DEBUG=false) the app
# refuses to start with them, so set real values via env vars / a secret manager.
API_KEY_SECRET=dev-signing-secret
# Operator token for /admin/* and /devices/register (must differ from device keys)
ADMIN_API_TOKEN=dev-admin-token

# Outbox Relay
OUTBOX_POLL_INTERVAL=5.0
OUTBOX_BATCH_SIZE=100

# Clinical Thresholds
HR_MIN=30
HR_MAX=250
SYSTOLIC_MIN=60
SYSTOLIC_MAX=250
DIASTOLIC_MIN=40
DIASTOLIC_MAX=150
SPO2_MIN=50.0
SPO2_MAX=100.0
# Reject measurement timestamps more than this many seconds in the future
MAX_FUTURE_SKEW_SECONDS=60
